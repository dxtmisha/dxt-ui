{
  "name": "@dxtmisha/functional",
  "private": false,
  "version": "1.11.2",
  "type": "module",
  "description": "A comprehensive library of utilities, base classes, and Vue 3 composables for reactive web development. Extends @dxtmisha/functional-basic with Composition API.",
  "keywords": [
    "functional",
    "utilities",
    "helpers",
    "typescript",
    "vue",
    "vue3",
    "composition-api",
    "composables",
    "classes",
    "reactivity",
    "api-client",
    "storage",
    "i18n",
    "geo",
    "datetime",
    "cache",
    "ui"
  ],
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui/tree/main/packages/functional-basic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git",
    "directory": "packages/functional-basic"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "library": "dxt-library",
    "dxt-types": "dxt-types",
    "prepublishOnly": "npm run library && npm run build",
    "public": "npm publish --access public"
  },
  "files": [
    "dist",
    "ai-types.txt",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "main": "dist/library.js",
  "module": "dist/library.js",
  "types": "dist/library.d.ts",
  "exports": {
    ".": {
      "import": "./dist/library.js",
      "types": "./dist/library.d.ts"
    },
    "./flags": {
      "import": "./dist/flags.js",
      "types": "./dist/flags.d.ts"
    },
    "./types/*": "./dist/*"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@dxtmisha/media": "*",
    "@dxtmisha/functional-basic": "*",
    "vue": "*"
  },
  "peerDependenciesMeta": {
    "@dxtmisha/media": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {},
  "sideEffects": false
}