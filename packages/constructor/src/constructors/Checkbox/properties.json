{
  "#input": {},
  "#body": {},
  "#item": {},
  "#icon": {},
  "#loading": {},
  "#info": {},
  "#label": {},
  "focus": {
    "_type": "none"
  },
  "checked": {
    "_type": "none"
  },
  "disabled": {
    "_type": "none"
  },
  "~block": {
    "display": "flex",
    "#body": {
      "flex-grow": "1"
    },
    "_default": true
  },
  "~adaptive": {
    "~rightAlways": {
      "#track": {
        "order": "4"
      },
      "#item": {
        "order": "4"
      },
      "#info": {
        "order": "2"
      }
    },
    "group|right": {
      "link|adaptive-icon": "{??adaptive.rightAlways}",
      "_type": "media-max-group"
    }
  },
  "container": {
    "group|right": {
      "link|adaptive-icon": "{??adaptive.rightAlways}",
      "_type": "container-max-group"
    }
  },
  "~required": {
    "color": {
      "_type": "var"
    }
  },
  "~itemCenter": {
    "_default": true
  },
  "&__input:focus ~ *": {
    "link:focus": "{??focus}"
  },
  "&__input:checked ~ *": {
    "link:checked": "{??checked}"
  },
  "&__input:disabled ~ *": {
    "link:disabled": "{??disabled}"
  }
}
