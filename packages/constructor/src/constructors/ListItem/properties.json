{
  "paddingX": {
    "_type": "var"
  },
  "paddingY": {
    "_type": "var"
  },
  "shift": {
    "_type": "var"
  },
  "height": {
    "_type": "var"
  },
  "border-width": {
    "_type": "var"
  },
  "border-color": {
    "_type": "var"
  },
  "transition-property": "background-color, background-image, border, box-shadow",
  "transition-duration": "{d.sys.transitionDuration.fade.enter}",
  "transition-function": "{d.sys.transitionFunction.standard}",
  "#body": {},
  "#context": {},
  "#label": {},
  "#highlight": {},
  "#prefix": {},
  "#caption": {},
  "#description": {},
  "#icon": {},
  "#trailing": {},
  "#control": {},
  "#badge": {},
  "#input": {},
  "~focus": {},
  "~open": {},
  "~selected": {
    "_prop": false
  },
  "~selectedChild": {},
  "~readonly": {},
  "~disabled": {},
  "~iconTop": {},
  "~iconAlign": {
    "~center": {},
    "~edge": {},
    "_default": "center"
  },
  "~controlPosition": {
    "~start": {
      "#control": {
        "order": "4"
      }
    },
    "~end": {
      "#control": {
        "order": "28"
      }
    },
    "group|auto": {
      "link|controlPosition-start": "{??controlPosition.start}",
      "_type": "media-group"
    },
    "_default": "end"
  },
  "~fill": {
    "_type": "state",
    "_var": true,
    "_style": true
  },
  "~divider": {}
}