{
  "name": "@dxtmisha/media",
  "private": false,
  "version": "0.6.0",
  "type": "module",
  "description": "Media resources library for DXT UI containing country flags and geographical data",
  "keywords": [
    "flags",
    "countries",
    "svg",
    "geo",
    "ui",
    "dxt",
    "media"
  ],
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui/tree/main/packages/media",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git",
    "directory": "packages/media"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "flags": "dxt-flags",
    "prepublishOnly": "npm run build",
    "publish-to-npm": "npm publish --access public"
  },
  "main": "dist/library.js",
  "module": "dist/library.js",
  "types": "./dist/src/library.d.ts",
  "exports": {
    ".": {
      "import": "./dist/library.js",
      "types": "./dist/src/library.d.ts"
    },
    "./flags": {
      "import": "./dist/flags.js",
      "types": "./dist/src/flags.d.ts"
    },
    "./flags.webp": "./dist/flags.webp",
    "./style.css": "./dist/style.css",
    "./types/*": "./dist/*",
    "./types/**/*.d.ts": "./dist/src/**/*.d.ts"
  },
  "dependencies": {},
  "engines": {
    "node": ">=20.0.0"
  },
  "ui-priority": 50
}