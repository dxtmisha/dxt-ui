{
  "name": "@dxtmisha/wiki",
  "private": false,
  "version": "0.86.1",
  "type": "module",
  "description": "Wiki documentation and storybook utilities for DXT UI design system",
  "keywords": [
    "wiki",
    "storybook",
    "documentation",
    "ui",
    "dxt",
    "design-system",
    "components",
    "utilities"
  ],
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui/tree/main/packages/wiki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git",
    "directory": "packages/wiki"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "publish-to-npm": "npm publish --access public"
  },
  "files": [
    "dist",
    "src/media/functional",
    "src/styles",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "main": "dist/library.js",
  "module": "dist/library.js",
  "types": "dist/library.d.ts",
  "exports": {
    ".": {
      "import": "./dist/library.js",
      "types": "./dist/library.d.ts"
    },
    "./functional/*": "./src/media/functional/*.mdx",
    "./media": {
      "import": "./dist/media.js",
      "types": "./dist/media.d.ts"
    },
    "./storybook": {
      "import": "./dist/storybook.js",
      "types": "./dist/storybook.d.ts"
    },
    "./storybook/styles": "./src/styles/storybookStyle.scss"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {},
  "peerDependencies": {
    "@dxtmisha/functional": "*",
    "@dxtmisha/media": "*",
    "@dxtmisha/styles": "*",
    "@mdx-js/react": "*",
    "@storybook/addon-docs": "*",
    "react": "*",
    "vue": "*"
  },
  "ui-priority": 400
}