{
  "name": "@dxtmisha/nitro-basic",
  "private": false,
  "version": "0.1.6",
  "type": "module",
  "description": "A foundational utility library for building robust Server-Side Rendering (SSR) applications with Vue 3 and Nitro.",
  "keywords": [
    "nitro",
    "vue",
    "vue3",
    "ssr",
    "server-side-rendering",
    "h3",
    "nuxt",
    "framework",
    "dxtmisha"
  ],
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui/tree/main/packages/nitro-basic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git",
    "directory": "packages/nitro-basic"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "component": "dxt-component",
    "library": "dxt-library",
    "types": "dxt-types",
    "prepublishOnly": "npm run library && npm run build",
    "publish-to-npm": "npm publish --access public"
  },
  "files": [
    "dist",
    "ai-description.txt",
    "ai-doc.ru.txt",
    "ai-doc.txt",
    "ai-types.txt",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "main": "dist/library.js",
  "module": "dist/library.js",
  "types": "dist/src/library.d.ts",
  "exports": {
    ".": {
      "import": "./dist/library.js",
      "types": "./dist/src/library.d.ts"
    },
    "./plugin": {
      "import": "./dist/library-plugin.js",
      "types": "./dist/src/library-plugin.d.ts"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@dxtmisha/functional": "*",
    "@dxtmisha/functional-basic": "*",
    "h3": "*",
    "nitro": "*",
    "nitropack": "*",
    "vue": "*",
    "vue-router": "*"
  },
  "sideEffects": false,
  "ui-priority": 300
}