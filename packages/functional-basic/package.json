    "translate",
    "translation",
    "datetime",
    "date",
    "formatters",
    "units",
    "cache",
    "cookie",
    "storage",
    "localStorage",
    "sessionStorage",
    "meta",
    "seo",
    "open-graph",
    "twitter-card",
    "dom",
    "events",
    "broadcast-channel",
    "search-list",
    "query",
    "hash",
    "phone",
    "icons",
    "flags",
    "tree-shakeable",
    "dxt"
  ],
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui/tree/main/packages/functional-basic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git",
    "directory": "packages/functional-basic"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "NODE_OPTIONS=\"--no-webstorage\" vitest",
    "library": "dxt-library",
    "types": "dxt-types",
    "prepublishOnly": "npm run library && npm run build",
    "publish-to-npm": "npm publish --access public"
  },
  "files": [
    "dist",
    "ai-description.md",
    "ai-doc.md",
    "ai-types.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "main": "dist/library.js",
  "module": "dist/library.js",
  "types": "dist/library.d.ts",
  "exports": {
    ".": {
      "import": "./dist/library.js",
      "types": "./dist/library.d.ts"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@dxtmisha/media": "*"
  },
  "sideEffects": false,
  "ui-priority": 100
