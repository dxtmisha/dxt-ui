{
  "name": "@dxtmisha/figma-code",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "description": "Structured TypeScript abstraction layer for Figma Plugin development, focused on node manipulation, state management, and messaging.",
  "keywords": [
    "figma",
    "figma-plugin",
    "typescript",
    "abstraction",
    "storage",
    "messenger"
  ],
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui/tree/main/packages/figma-code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git",
    "directory": "packages/figma-code"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "library": "dxt-library",
    "types": "dxt-types",
    "prepublishOnly": "npm run library && npm run build",
    "public-to-npm": "npm publish --access public"
  },
  "files": [
    "dist",
    "ai-description.txt",
    "ai-doc.txt",
    "ai-types.txt",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "main": "dist/library.js",
  "module": "dist/library.js",
  "types": "dist/src/library.d.ts",
  "exports": {
    ".": {
      "import": "./dist/library.js",
      "types": "./dist/src/library.d.ts"
    }
  },
  "peerDependencies": {
    "@dxtmisha/functional-basic": "*",
    "@figma/plugin-typings": "*"
  },
  "dependencies": {},
  "devDependencies": {},
  "sideEffects": false
}