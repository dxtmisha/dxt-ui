{
  "name": "@dxtmisha/figma-code",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "[description]",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "library": "dxt-library",
    "types": "dxt-types",
    "prepublishOnly": "npm run library && npm run build",
    "public": "npm publish --access public"
  },
  "files": [
    "dist",
    "ai-description.txt",
    "ai-doc.ru.txt",
    "ai-doc.txt",
    "ai-types.txt",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "main": "dist/library.js",
  "module": "dist/library.js",
  "types": "dist/library.d.ts",
  "exports": {
    ".": {
      "import": "./dist/library.js",
      "types": "./dist/library.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./types/*": "./dist/*",
    "./types/**/*.d.ts": "./dist/**/*.d.ts"
  },
  "dependencies": {},
  "devDependencies": {},
  "sideEffects": false
}