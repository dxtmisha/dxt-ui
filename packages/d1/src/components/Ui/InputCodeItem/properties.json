{
  "main": "{d.inputCodeItem}",
  "padding": "{sys.spacing.sm}",
  "background-color": "{sys.palette.surface}",
  "background-opacity": "{sys.opacity.primary.high}",
  "backdrop-filter": "{sys.blur.md}",
  "border-radius": "{??height} * {?sys.rounded.adaptive.md}",
  "gradient": "{sys.palette.primary}",
  "gradient-opacity": "0",
  "after": {
    "position": "absolute",
    "inset": "0",
    "border-width": "{sys.spacing.outline}",
    "border-color": "{sys.palette.outline}",
    "border-opacity": "{sys.opacity.outline}",
    "border-radius": "inherit"
  },
  "hover": {
    "gradient-opacity": "{sys.opacity.hover}"
  },
  "focusWithin": {
    "gradient-opacity": "{sys.opacity.focus}",
    "outline-color": "{sys.palette.primary}",
    "outline-opacity": "{sys.opacity.outline}",
    "outline-width": "{ref.spacing.1}",
    "after": {
      "border-color": "{sys.palette.primary}",
      "border-width": "{ref.spacing.2px}",
      "border-opacity": "{sys.opacity.primary.high}"
    }
  },
  "disabled": {
    "color-opacity": "{sys.opacity.surface.disabled}",
    "background-color": "{sys.palette.surface}",
    "after": {
      "border-color": "{sys.palette.outline}",
      "border-opacity": "calc({sys.opacity.outline} * {sys.opacity.surface.disabled})"
    }
  },
  "~success": {
    "gradient": "{sys.palette.success}",
    "after": {
      "border-color": "{sys.palette.success}",
      "border-opacity": "{sys.opacity.surface.high}"
    },
    "focusWithin": {
      "outline-color": "{sys.palette.success}",
      "after": {
        "border-color": "{sys.palette.success}"
      }
    }
  },
  "~error": {
    "gradient": "{sys.palette.error}",
    "after": {
      "border-color": "{sys.palette.error}",
      "border-opacity": "{sys.opacity.surface.high}"
    },
    "focusWithin": {
      "outline-color": "{sys.palette.error}",
      "after": {
        "border-color": "{sys.palette.error}"
      }
    }
  },
  "~size": {
    "link|size": "{?field.size}",
    "_default": "md"
  }
}
