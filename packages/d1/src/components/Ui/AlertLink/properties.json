{
  "main": "{d.alertLink}",
  "linkGap": "{sys.spacing.x}",
  "link|font": "{font.bodyMedium}",
  "#label": {
    "palette-color": "{sys.palette.primary}",
    "color-opacity": "{sys.opacity.surface.high}"
  },
  "hover": {
    "#label": {
      "text-decoration": "underline",
      "text-decoration-style": "dashed",
      "color-opacity": "{sys.opacity.surface.high} + {sys.opacity.hover}"
    }
  }
}
