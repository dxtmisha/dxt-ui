{
  "main": "{d.selectableArea}",
  "#square": {
    "background-color": "{sys.palette.onSurface}",
    "background-opacity": "{sys.opacity.overlay}",
    "border-width": "{sys.spacing.outline}",
    "border-color": "{sys.palette.onSurface}",
    "border-opacity": "{sys.opacity.scrim}"
  },
  "#item": {
    "~selected": {
      "before": {
        "palette-background": "{sys.palette.primary}",
        "background-opacity": "{sys.opacity.pressed}"
      }
    }
  }
}
