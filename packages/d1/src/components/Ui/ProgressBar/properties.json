{
  "main": "{d.progressBar}",
  "gap": "{sys.spacing.x}",
  "height": "{ref.spacing.2}",
  "font": "{font.bodySmall}",
  "color": "{sys.palette.onSurface}",
  "color-opacity": "{sys.opacity.surface.medium}",
  "border-radius": "{sys.rounded.full}",
  "#item": {
    "#label": {
      "padding-bottom": "{sys.spacing.x}"
    },
    "#progress": {
      "palette-background": "{sys.palette.onSurface}",
      "background-opacity": "{sys.opacity.scrim}",
      "backdrop-filter": "{sys.blur.sm}"
    },
    "~focus": {
      "#progress": {
        "palette-background": "{sys.palette.primaryVariant}",
        "background-opacity": "{sys.opacity.primary.high}"
      }
    },
    "~palette": {
      "#progress": {
        "palette-background": "{sys.palette.primary}",
        "background-opacity": "{sys.opacity.primary.high}"
      }
    },
    "~space": {
      "#progress": {
        "background-opacity": "{sys.opacity.disabled}"
      }
    }
  },
  "@@palette": "{palette}"
}
