{
  "main": "{d.bulletItem}",
  "padding-left": "{sys.spacing.md}",
  "before": {
    "content": "'•'",
    "palette-color": "{sys.palette.onSurface}",
    "color-opacity": "{sys.opacity.surface.high}"
  },
  "~size": {
    "~sm": {
      "font": "{font.bodySmall}"
    },
    "~md": {
      "font": "{font.bodyMedium}"
    },
    "~lg": {
      "font": "{font.bodyLarge}"
    },
    "_default": "md"
  },
  "@@palette": "{palette}"
}