{
  "main": "{d.bulletItem}",
  "padding-left": "{sys.spacing.xl}",
  "before": {
    "color": "{sys.palette.primary}"
  },
  "~size": {
    "~sm": {
      "font": "{font.bodySmall}",
      "padding": "{sys.spacing.xs}"
    },
    "~md": {
      "font": "{font.bodyMedium}",
