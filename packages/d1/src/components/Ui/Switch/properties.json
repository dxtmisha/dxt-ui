{
  "main": "{d.switch}",
  "comp": {
    "backgroundColor": "{sys.palette.scrim}",
    "checked": {
      "backgroundColor": "{sys.palette.primary}"
    },
    "track": {
      "width": "{ref.spacing.10}",
      "height": "{ref.spacing.5}"
    },
    "item": {
      "width": "{ref.spacing.10}",
      "height": "{ref.spacing.10}"
    },
    "_type": "var"
  },
  "required": {
    "color": "{sys.palette.error}",
    "colorOpacity": "{sys.opacity.surface.high}",
    "_type": "var"
  },
  "#body": {
    "gap": "{sys.spacing.md}"
  },
  "#track": {
    "background-color": "{??comp.backgroundColor}",
    "background-opacity": "{sys.opacity.scrim}",
    "border-radius": "{sys.rounded.full}",
    "hover": {
    }
  },
  "#item": {
    "color": "{??comp.backgroundColor}",
    "background-color": "{??comp.backgroundColor}",
    "background-opacity": "0"
  },
  "#icon": {
    "width": "{ref.spacing.6}",
    "height": "{ref.spacing.6}",
    "background-color": "{sys.palette.onPrimary}",
    "background-opacity": "{sys.opacity.primary.high}",
    "border-radius": "{sys.rounded.full}",
    "box-shadow": "{sys.shadow.sm}",
    "backdrop-filter": "{sys.blur.md}"
  },
  "#loading": {
    "padding": "{sys.spacing.xs}"
  },
  "#description": {
    "link|font": "{font.bodyMedium}",
    "color-opacity": "{sys.opacity.surface.medium}"
  },
  "focus-within": {
    "#item": {
      "background-opacity": "{sys.opacity.focus}"
    }
  },
  "checked": {
    "comp": {
      "backgroundColor": "{??comp.checked.backgroundColor}",
      "_type": "var"
    },
    "#icon": {
      "background-color": "{??comp.backgroundColor}"
    }
  },
  "disabled": {
    "comp": {
      "backgroundColor": "{sys.palette.scrim}",
      "checked": {
        "backgroundColor": "{sys.palette.scrim}"
      },
      "_type": "var"
    },
    "#track": {
      "background-opacity": "{sys.opacity.disabled}"
    },
    "#icon": {
      "background-color": "{sys.palette.onSurface}",
      "background-opacity": "{sys.opacity.primary.disabled}"
    }
  }
}
