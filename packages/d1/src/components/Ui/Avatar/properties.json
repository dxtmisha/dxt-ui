{
  "main": "{d.avatar}",
  "=?image-publicMaskSize": "58%",
  "color": "{sys.palette.onSurface}",
  "color-opacity": "{sys.opacity.surface.medium}",
  "palette-background": "{sys.palette.onSurface}",
  "background-opacity": "{sys.opacity.overlay}",
  "border-radius": "{sys.rounded.full}",
  "focus": {
    "outline": "{outline.md}"
  },
  "focus-visible": {
    "outline": "{outline.md}"
  },
  "hover": {
    "after": {
      "border-style": "solid",
      "border-width": "{sys.spacing.outline}",
      "border-color": "{sys.palette.outline}",
      "border-opacity": "{sys.opacity.outline}"
    }
  },
  "disabled": {
    "color-opacity": "{sys.opacity.surface.disabled}",
    "background-opacity": "0"
  },
  "~primary": {
    "color": "{sys.palette.onPrimary}",
    "color-opacity": "{sys.opacity.primary.high}",
    "palette-background": "{sys.palette.primary}",
    "background-opacity": "{sys.opacity.primary.high}",
    "backdrop-filter": "{sys.blur.md}"
  },
  "~size": {
    "xs": {
      "width": "{ref.spacing.8}",
      "font": "{font.labelMedium}"
    },
    "sm": {
      "width": "{ref.spacing.10}",
      "font": "{font.labelLarge}"
    },
    "md": {
      "width": "{ref.spacing.12}",
      "font": "{font.titleMedium}"
    },
    "lg": {
      "width": "{ref.spacing.14}",
      "font": "{font.titleLarge}"
    },
    "xl": {
      "width": "{ref.spacing.16}",
      "font": "{font.titleLarge}"
    },
    "_default": "md"
  },
  "@@palette": "{palette}"
}
