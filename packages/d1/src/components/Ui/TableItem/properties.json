{
  "main": "{d.tableItem}",
  "border-styleX": "dashed",
  "border-width": "{sys.spacing.outline}",
  "border-color": "{sys.palette.outline}",
  "border-opacity": "{sys.opacity.outline}",
  "paddingX": "{sys.spacing.xs}",
  "paddingY": "{sys.spacing.x}",
  "link|font": "{font.bodyMedium}",
  "#description": {
    "link|caption": "{??bodySmall}",
    "color-opacity": "{sys.opacity.surface.medium}"
  },
  "~selected": {
    "palette-background": "{sys.palette.primaryVariant}",
    "background-opacity": "{sys.opacity.overlay}"
  },
  "~disabled": {
    "color-opacity": "{sys.opacity.surface.disabled}",
    "#description": {
      "color-opacity": "{sys.opacity.surface.disabled}"
    }
  },
  "~dividerX": {
    "_default": true
  },
  "~dividerY": {
    "_default": true
  }
}
