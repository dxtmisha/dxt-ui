{
  "main": "{d.header}",
  "gap": "{sys.spacing.xs}",
  "#caption": {
    "color-opacity": "{sys.opacity.surface.medium}"
  },
  "~tag": {
    "~h1": {
      "#icon": {
        "font-size": "{sys.font.size.headlineSmall}"
      },
      "#label": {
        "link|font": "{font.headlineMedium}",
        "media|md": {
          "link|font": "{font.headlineLarge}"
        }
      }
    },
    "~h2": {
      "#icon": {
        "font-size": "{sys.font.size.xl}"
      },
      "#label": {
        "link|font": "{font.headlineSmall}",
        "media|md": {
          "link|font": "{font.headlineMedium}"
        }
      }
    },
    "~h3": {
      "#icon": {
        "font-size": "{sys.font.size.md}"
      },
      "#label": {
        "link|font": "{font.titleMedium}",
        "media|md": {
          "link|font": "{font.headlineSmall}"
        }
      }
    },
    "~h4": {
      "#icon": {
        "font-size": "{sys.font.size.xs}"
      },
      "#label": {
        "link|font": "{font.titleSmall}",
        "media|md": {
          "link|font": "{font.titleMedium}"
        }
      }
    },
    "~h5": {
      "#icon": {
        "font-size": "{sys.font.size.xs}"
      },
      "#label": {
        "link|font": "{font.labelMedium}",
        "media|md": {
          "link|font": "{font.titleSmall}"
        }
      }
    },
    "~h6": {
      "#icon": {
        "font-size": "{sys.font.size.xs}"
      },
      "#label": {
        "link|font": "{font.labelSmall}",
        "media|md": {
          "link|font": "{font.labelMedium}"
        }
      }
    }
  }
}