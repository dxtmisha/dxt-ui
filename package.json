{
  "name": "dxt-ui",
  "private": false,
  "version": "0.1.5",
  "description": "A modular Vue 3 UI library and design system constructor featuring AI-automated documentation, TypeScript support, and a flexible component architecture.",
  "keywords": [
    "vue",
    "vue3",
    "ui",
    "ui-library",
    "component-library",
    "design-system",
    "typescript",
    "vite",
    "storybook",
    "frontend",
    "scss"
  ],
  "type": "module",
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "package-library": "dxt-package library",
    "package-project": "dxt-package project",
    "package-figma": "dxt-package figma",
    "build-functional": "dxt-build-functional",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "packages/figma-translate/dist",
    "packages/figma-translate/package.json",
    "dist",
    "src/style.scss",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "exports": {
    "./figma-translate": {
      "import": "./dist/figma-translate.js",
      "types": "./dist/figma-translate.d.ts"
    },
    "./functional": {
      "import": "./dist/functional.js",
      "types": "./dist/functional.d.ts"
    },
    "./media": {
      "import": "./dist/media.js",
      "types": "./dist/media.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./scss": "./src/style.scss",
    "./types/*": "./dist/*"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@dxtmisha/configuration": "workspace:*",
    "@dxtmisha/constructor": "workspace:*",
    "@dxtmisha/figma": "workspace:*",
    "@dxtmisha/figma-translate": "workspace:*",
    "@dxtmisha/functional": "workspace:*",
    "@dxtmisha/functional-basic": "workspace:*",
    "@dxtmisha/media": "workspace:*",
    "@dxtmisha/scripts": "workspace:*",
    "@dxtmisha/styles": "workspace:*",
    "@dxtmisha/wiki": "workspace:*",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@dxtmisha/d1": "workspace:*",
    "@dxtmisha/storybook": "workspace:*",
    "@dxtmisha/test": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.123.0",
    "@google/genai": "^1.46.0",
    "@mdx-js/rollup": "^3.1.1",
    "@napi-rs/canvas": "^0.1.97",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/vue3-vite": "^10.3.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/tsconfig": "^0.9.0",
    "browserslist": "^4.28.1",
    "chromatic": "^15.3.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-storybook": "^10.3.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "lightningcss": "^1.32.0",
    "playwright": "^1.58.2",
    "puppeteer": "^24.40.0",
    "storybook": "^10.3.1",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-singlefile": "^2.3.2",
    "vite-plugin-svg-loader": "^0.0.2",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}
