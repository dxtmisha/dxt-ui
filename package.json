{
  "name": "dxt-ui",
  "private": false,
  "version": "0.1.5",
  "description": "A modular Vue 3 UI library and design system constructor featuring AI-automated documentation, TypeScript support, and a flexible component architecture.",
  "keywords": [
    "vue",
    "vue3",
    "ui",
    "ui-library",
    "component-library",
    "design-system",
    "typescript",
    "vite",
    "storybook",
    "frontend",
    "scss"
  ],
  "type": "module",
  "author": "dxtmisha@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/dxtmisha/dxt-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxtmisha/dxt-ui.git"
  },
  "bugs": {
    "url": "https://github.com/dxtmisha/dxt-ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "package-library": "dxt-package library",
    "package-project": "dxt-package project",
    "package-figma": "dxt-package figma",
    "build-functional": "dxt-build-functional",
    "build-packages": "dxt-build-packages",
    "build-publish-packages": "dxt-build-publish-packages",
    "prompt": "dxt-prompt",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "packages/zip/dist",
    "packages/zip/package.json",
    "dist",
    "src/style.scss",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "exports": {
    "./zip": {
      "import": "./dist/zip.js",
      "types": "./dist/zip.d.ts"
    },
    "./functional": {
      "import": "./dist/functional.js",
      "types": "./dist/functional.d.ts"
    },
    "./media": {
      "import": "./dist/media.js",
      "types": "./dist/media.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./scss": "./src/style.scss",
    "./types/*": "./dist/*"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@dxtmisha/configuration": "workspace:*",
    "@dxtmisha/constructor": "workspace:*",
    "@dxtmisha/figma": "workspace:*",
    "@dxtmisha/figma-code": "workspace:*",
    "@dxtmisha/figma-ref": "workspace:*",
    "@dxtmisha/functional": "workspace:*",
    "@dxtmisha/functional-basic": "workspace:*",
    "@dxtmisha/media": "workspace:*",
    "@dxtmisha/nitro-basic": "workspace:*",
    "@dxtmisha/scripts": "workspace:*",
    "@dxtmisha/styles": "workspace:*",
    "@dxtmisha/wiki": "workspace:*",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@dxtmisha/d1": "workspace:*",
    "@dxtmisha/demo": "workspace:*",
    "@dxtmisha/demo-test": "workspace:*",
    "@dxtmisha/figma-style": "workspace:*",
    "@dxtmisha/figma-translate": "workspace:*",
    "@dxtmisha/storybook": "workspace:*",
    "@dxtmisha/test": "workspace:*",
    "@dxtmisha/zip": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.126.0",
    "@google/genai": "^2.3.0",
    "@mdx-js/rollup": "^3.1.1",
    "@napi-rs/canvas": "^1.0.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/mdx2-csf": "^1.1.0",
    "@storybook/vue3-vite": "^10.4.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/tsconfig": "^0.9.1",
    "browserslist": "^4.28.2",
    "chromatic": "^16.10.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-plugin-storybook": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "fflate": "^0.8.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "nitro": "^3.0.260429-beta",
    "playwright": "^1.60.0",
    "storybook": "^10.4.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plugin-svg-loader": "^0.0.2",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  }
}